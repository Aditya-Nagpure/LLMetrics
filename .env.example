# LLM Provider — "groq" or "anthropic"
LLM_PROVIDER=groq
LLM_MODEL=llama3-8b-8192

# API Keys
GROQ_API_KEY=

# Storage — "jsonl" or "sqlite"
STORAGE_BACKEND=jsonl
JSONL_PATH=data/traces.jsonl
SQLITE_PATH=data/llmetrics.db

# Evaluation
ENABLE_LLM_JUDGE=false
LLM_JUDGE_MODEL=llama3-8b-8192
FAITHFULNESS_THRESHOLD=0.6

# ChromaDB
CHROMA_COLLECTION=documents
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Retrieval
RETRIEVER_TOP_K=10
RERANKER_TOP_N=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2